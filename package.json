{
  "name": "content-starter",
  "version": "1.0.0",
  "description": "Default SCSS starter (Base + Component architecture, modern @use/@forward).",
  "private": true,
  "scripts": {
    "build": "sass Content/Styles/Base.scss:Content/Styles/Base.css --no-source-map --style=compressed",
